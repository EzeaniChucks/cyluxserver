# Cylux Server — Environment Variables
# Copy this file to .env and fill in the values before starting the server.
# NEVER commit .env to version control.

# --- DATABASE ---
DATABASE_URL="postgres://guardian_user:password@localhost:5432/cylux"

# --- REQUIRED: Server will crash at startup if these are missing ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=05866023b6c94dd18019773dcd0960d58614fd2329cc9a552598ce3b60ace83356e893175da9ef8cecafe4afae57fdef48762736a7aa67fc21d8c15e1f78793d
JWT_REFRESH_SECRET=67e56381de30f7f822e35fa73b7c3908d3af86bd40f1caac69c55126261bfffd1e6afa877191289c42edba64e22a6782917c1f501d70bd0554109737bbc7aaee
DEVICE_JWT_SECRET=4992e2fa90cbdcb240734c7f8bced567b6e5a2ab53b8049d06b23ce23d034554482c074c7f9ddd14c370864dd8d93b068d9a88f82430d3e89682160a127e7b4b

ADMIN_SEED_SECRET=5ow458g10yt93v4RF2u9rv02tr82tr83rfc725d37268ret792cskdjfhfutraedjpawefG_Wfgw

GEMINI_API_KEY=AIzaSyCudbakdGzOefrqOlIrhCytHP80nbQPoOQ

# --- CORS ---
# Comma-separated list of allowed origins.
# In production, set this to your actual frontend domain(s).
# If NODE_ENV=production and this is not set, the server will refuse to start.
CORS_ORIGINS=http://localhost:3001

# --- EMAIL (SendGrid) ---
SENDGRID_API_KEY=SG.your_key_here
FROM_EMAIL=noreply@cylux.co

# --- STRIPE ---
# Secret key from dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret — dashboard.stripe.com → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create in dashboard.stripe.com → Products → Add Price
# Each paid tier needs two prices: one monthly, one annual recurring.
# Format: price_<random> (e.g. price_1OaBcDEfGhIjKlMn) — NOT price_<amount>.
# Enterprise has no price IDs (contactSalesOnly = true, billing handled manually).
STRIPE_PRICE_BASIC_MONTHLY=price_1TASysQzkznuU9UjSnZCFGg3
STRIPE_PRICE_BASIC_ANNUAL=price_1TAT5LQzkznuU9Uj0pgBzIlW

STRIPE_PRICE_PREMIUM_MONTHLY=price_1TATCaQzkznuU9UjKWXT8gP4
STRIPE_PRICE_PREMIUM_ANNUAL=price_1TATDEQzkznuU9Uj7MbjUFpF

STRIPE_PRICE_PREMIUM_PLUS_MONTHLY=price_1TATEqQzkznuU9Uj6w0Ahn2n
STRIPE_PRICE_PREMIUM_PLUS_ANNUAL=price_1TATGQQzkznuU9UjM5OE88aE

# --- STRIPE CONNECT (payouts to influencers & parents) ---
# Create at dashboard.stripe.com → Connect → Settings → Get started
STRIPE_CONNECT_CLIENT_ID=ca_your_connect_client_id
# Webhook secret for the /api/wallet/connect/webhook endpoint
# Create at dashboard.stripe.com → Webhooks → Add endpoint → listen for account.updated
STRIPE_WEBHOOK_SECRET_CONNECT=whsec_your_connect_webhook_secret

# --- GEO / VPN DETECTION (ipdata.co) ---
# Used for country/currency detection and VPN flagging at registration.
# Free tier: 1,500 requests/day. Get a key at https://ipdata.co
# If not set, the server falls back to timezone + locale signals only (no VPN detection).
IPDATA_API_KEY=

# --- SAMSUNG SMARTTHINGS (Smart TV control) ---
# Register an app at https://developer.smartthings.com → My Apps → New App
# Set the redirect URI to: https://yourdomain.com/api/smart-devices/samsung/callback
# Scopes required: r:devices:* x:devices:*
SMARTTHINGS_CLIENT_ID=
SMARTTHINGS_CLIENT_SECRET=
SMARTTHINGS_REDIRECT_URI=http://localhost:3001/api/smart-devices/samsung/oauth-callback

# --- LG / OTHER TVs via HOME ASSISTANT ---
# No server-side env vars needed.
# Parents provide their own HA URL + long-lived token via the parent app UI.
# See: POST /api/smart-devices/home-assistant

# --- OPTIONAL ---
PORT=3001
NODE_ENV=development
# Frontend URL — used to redirect after Samsung OAuth callback
WEBSITE_URL=http://localhost:3000
