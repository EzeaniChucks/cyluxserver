{
  "name": "cylux-server",
  "version": "1.0.0",
  "description": "Backend engine for the Cylux child monitoring platform, featuring TypeORM, Express, and Gemini AI integration.",
  "main": "backend/server.ts",
  "scripts": {
    "build": "npx tsc",
    "test": "jest",
    "start": "node dist/src/index.js",
    "dev": "npx tsc && nodemon src/index.ts",
    "typeorm": "ts-node ./node_modules/typeorm/cli.js",
    "migrate:generate": "typeorm-ts-node-commonjs migration:generate src/migrations/$npm_config_name -d src/database.ts",
    "migrate:run": "typeorm-ts-node-commonjs migration:run -d src/database.ts",
    "migrate:revert": "typeorm-ts-node-commonjs migration:revert -d src/database.ts",
    "migrate:create": "typeorm-ts-node-commonjs migration:create src/migrations/$npm_config_name",
    "migration:show": "npm run typeorm migration:show -- -d src/database.ts"
  },
  "dependencies": {
    "@google/genai": "^1.34.0",
    "@sendgrid/mail": "^8.1.4",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "firebase-admin": "^12.7.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.475.0",
    "nodemon": "^3.1.11",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "stripe": "^20.3.1",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/helmet": "^0.0.48",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3"
  },
  "keywords": [
    "parental-control",
    "monitoring",
    "safety",
    "gemini-ai",
    "typeorm"
  ],
  "author": "Cylux Engineering",
  "license": "MIT"
}
